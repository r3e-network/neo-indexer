# Supabase/Postgres connection string
# Format: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# CSV directory where DeepLogger writes files
LOG_DIR=/neo-data/logs

# HTTP health server port
HTTP_PORT=8080
