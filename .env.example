# Supabase / Postgres connection string for the Rust pusher
# Use session mode (port 5432) for DDL, transaction mode (port 6543) for DML
# Format: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Next.js frontend
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
NEXT_PUBLIC_REFRESH_MS=15000

# Service role key for server-side operations (KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# Supabase CLI access token (for migrations, optional)
SUPABASE_ACCESS_TOKEN=your-access-token-from-supabase-account
